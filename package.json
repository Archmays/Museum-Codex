{
  "name": "museum-codex-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && python scripts/materialize_museum_09b_media.py --output dist",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:museum-08": "playwright test e2e/museum-08.spec.ts",
    "test:e2e:museum-09b": "playwright test e2e/museum-09b.spec.ts",
    "check:build": "node scripts/verify-build.mjs",
    "check:museum-04-budgets": "node scripts/verify-museum-04-budgets.mjs",
    "check:museum-05b-budgets": "node scripts/verify-museum-05b-budgets.mjs",
    "check:museum-06-paths": "node --experimental-strip-types scripts/benchmark-museum-06-paths.mjs",
    "check:museum-06-budgets": "node scripts/verify-museum-06-budgets.mjs",
    "check:museum-07-budgets": "node scripts/verify-museum-07-budgets.mjs",
    "check:museum-08-search": "node --experimental-strip-types scripts/benchmark-museum-08-search.mjs",
    "check:museum-08-budgets": "node scripts/verify-museum-08-budgets.mjs",
    "check:museum-09b-search": "node scripts/benchmark-museum-09b-search.mjs",
    "check:museum-09b-budgets": "node scripts/verify-museum-09b-budgets.mjs",
    "check:safety": "node scripts/scan-repository.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run check:build && npm run check:safety"
  },
  "dependencies": {
    "graphology": "0.26.0",
    "maplibre-gl": "5.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "sigma": "3.0.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
