{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/common/evidence.schema.json",
  "title": "Museum evidence",
  "type": "object",
  "required": [
    "schema_version", "id", "entity_type", "claim_ids", "stance", "evidence_kind",
    "source_ids", "source_license_bindings", "locator", "summary", "original_language", "extracted_at",
    "extraction_method", "reliability_note", "lifecycle_status", "data_version"
  ],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "type": "string", "pattern": "^evidence:[a-z0-9][a-z0-9._-]*$" },
    "entity_type": { "const": "evidence" },
    "claim_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^claim:[a-z0-9][a-z0-9._-]*$" }
    },
    "stance": { "enum": ["supports", "contradicts", "contextualizes"] },
    "evidence_kind": { "enum": ["archival_record", "correspondence", "collection_record", "catalogue", "scholarly_analysis", "curatorial_assessment", "observation", "dataset_record", "computational_result", "image_technical_record", "other"] },
    "source_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^source:[a-z0-9][a-z0-9._-]*$" }
    },
    "source_license_bindings": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/sourceLicenseBinding" }
    },
    "locator": {
      "type": "object", "minProperties": 1,
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "section": { "type": "string", "minLength": 1 },
        "record_id": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "fragment": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "summary": { "type": "string", "minLength": 1 },
    "short_excerpt": { "type": ["string", "null"] },
    "raw_snapshot_refs": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["snapshot_id", "body_sha256", "source_object_id", "raw_locator"],
        "properties": {
          "snapshot_id": { "type": "string", "pattern": "^snapshot:[a-z][a-z0-9_]*:[a-z0-9.:_-]+$" },
          "body_sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "source_object_id": { "type": "string", "minLength": 1 },
          "raw_locator": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "original_language": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/languageTag" },
    "extracted_at": { "type": "string", "format": "date-time" },
    "extraction_method": { "enum": ["manual", "api_field", "ocr_reviewed", "computed"] },
    "reliability_note": { "type": "string", "minLength": 1 },
    "computation": {
      "type": "object",
      "required": ["algorithm", "version", "input_dataset_release", "parameters", "reproducibility_note"],
      "properties": {
        "algorithm": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "input_dataset_release": { "type": "string", "minLength": 1 },
        "parameters": { "type": "object" },
        "reproducibility_note": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "lifecycle_status": { "enum": ["candidate", "reviewed", "publishable", "published", "disputed", "deprecated", "withdrawn"] },
    "data_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" }
  },
  "allOf": [
    {
      "if": { "properties": { "evidence_kind": { "const": "computational_result" } }, "required": ["evidence_kind"] },
      "then": { "required": ["computation"], "properties": { "extraction_method": { "const": "computed" } } }
    }
  ],
  "additionalProperties": false
}
