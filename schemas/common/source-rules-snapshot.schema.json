{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/common/source-rules-snapshot.schema.json",
  "title": "Museum source rules snapshot",
  "type": "object",
  "required": ["schema_version", "snapshot_id", "generated_at", "sources"],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["source_id", "registry_source_id", "registry_identity", "license_rules_snapshot_hash", "license_rules"],
        "properties": {
          "source_id": { "type": "string", "pattern": "^source:[a-z0-9][a-z0-9._-]*$" },
          "registry_source_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "registry_identity": { "$ref": "https://museum-codex.example/schemas/common/source.schema.json#/properties/registry_identity" },
          "license_rules_snapshot_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "license_rules": {
            "type": "array", "minItems": 1,
            "items": { "$ref": "https://museum-codex.example/schemas/common/source.schema.json#/$defs/licenseRule" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
