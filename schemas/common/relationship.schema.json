{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/common/relationship.schema.json",
  "title": "Museum relationship",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "entity_type",
    "branch_id",
    "relationship_type",
    "relationship_semantics",
    "source_entity_id",
    "target_entity_id",
    "directed",
    "temporal_scope",
    "place_scope",
    "evidence_level",
    "historical_relationship_strength",
    "evidence_confidence",
    "computational_similarity",
    "curatorial_relevance",
    "claim_ids",
    "source_ids",
    "source_license_bindings",
    "curatorial_note",
    "public_display",
    "is_algorithmic",
    "review_status",
    "reviewed_by",
    "reviewed_at",
    "lifecycle_status",
    "data_version"
  ],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "type": "string", "pattern": "^(rel|art-rel|bio-rel):[a-z0-9][a-z0-9._-]*$" },
    "entity_type": { "const": "relationship" },
    "branch_id": { "enum": ["global", "art", "biology", "music", "games", "civilization", "science"] },
    "relationship_type": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "relationship_semantics": {
      "enum": ["historical_direct", "historical_context", "curatorial_comparison", "computational_similarity", "discipline_specific"]
    },
    "source_entity_id": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/stableId" },
    "target_entity_id": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/stableId" },
    "directed": { "type": "boolean" },
    "temporal_scope": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/timeSpan" },
    "place_scope": {
      "type": "object",
      "required": ["place_ids", "description"],
      "properties": {
        "place_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^place:[a-z0-9][a-z0-9._-]*$" },
          "uniqueItems": true
        },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "evidence_level": { "enum": ["A", "B", "C"] },
    "historical_relationship_strength": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "evidence_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "computational_similarity": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "curatorial_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
    "claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^claim:[a-z0-9][a-z0-9._-]*$" },
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^source:[a-z0-9][a-z0-9._-]*$" },
      "uniqueItems": true
    },
    "source_license_bindings": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/sourceLicenseBinding" }
    },
    "curatorial_note": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/localizedText" },
    "public_display": { "type": "boolean" },
    "is_algorithmic": { "type": "boolean" },
    "algorithm": {
      "type": "object",
      "required": ["name", "version", "input_dataset_release", "method_note"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "input_dataset_release": { "type": "string", "minLength": 1 },
        "method_note": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "review_status": { "enum": ["candidate", "sourced", "reviewed", "verified", "publishable", "published", "disputed", "deprecated", "withdrawn"] },
    "reviewed_by": { "type": "string", "minLength": 1 },
    "reviewed_at": { "type": "string", "format": "date" },
    "lifecycle_status": { "enum": ["candidate", "reviewed", "publishable", "published", "disputed", "deprecated", "withdrawn"] },
    "data_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" }
  },
  "allOf": [
    {
      "if": { "properties": { "is_algorithmic": { "const": true } }, "required": ["is_algorithmic"] },
      "then": {
        "required": ["algorithm"],
        "properties": {
          "relationship_semantics": { "const": "computational_similarity" },
          "evidence_level": { "const": "C" },
          "computational_similarity": { "type": "number" }
        }
      }
    },
    {
      "if": { "properties": { "relationship_semantics": { "const": "historical_direct" } }, "required": ["relationship_semantics"] },
      "then": {
        "properties": {
          "is_algorithmic": { "const": false },
          "computational_similarity": { "type": "null" }
        }
      }
    },
    {
      "if": { "properties": { "is_algorithmic": { "const": false } }, "required": ["is_algorithmic"] },
      "then": { "properties": { "computational_similarity": { "type": "null" } } }
    },
    {
      "if": { "properties": { "relationship_semantics": { "const": "computational_similarity" } }, "required": ["relationship_semantics"] },
      "then": {
        "required": ["algorithm"],
        "properties": {
          "is_algorithmic": { "const": true },
          "evidence_level": { "const": "C" },
          "historical_relationship_strength": { "type": "null" },
          "computational_similarity": { "type": "number" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "relationship_semantics": {
            "enum": ["curatorial_comparison", "computational_similarity", "discipline_specific"]
          }
        },
        "required": ["relationship_semantics"]
      },
      "then": { "properties": { "historical_relationship_strength": { "type": "null" } } }
    }
  ]
}
