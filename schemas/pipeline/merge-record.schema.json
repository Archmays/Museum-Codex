{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/pipeline/merge-record.schema.json",
  "title": "Museum reversible identity merge record",
  "type": "object",
  "required": ["schema_version", "id", "entity_type", "proposal_id", "decision_id", "status", "survivor_candidate_id", "loser_candidate_ids", "alias_mappings", "loser_ids_retained", "reversible", "input_record_hashes", "mapping_before_hash", "mapping_after_hash", "status_history"],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "type": "string", "pattern": "^merge-record:[0-9a-f-]{36}$" },
    "entity_type": { "const": "merge_record" },
    "proposal_id": { "type": "string", "pattern": "^identity-proposal:" },
    "decision_id": { "type": "string", "pattern": "^review-decision:" },
    "status": { "enum": ["applied", "reversed"] },
    "survivor_candidate_id": { "type": "string", "pattern": "^candidate:" },
    "loser_candidate_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^candidate:" } },
    "alias_mappings": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["alias_id", "survivor_id", "active"],
        "properties": {
          "alias_id": { "type": "string", "pattern": "^candidate:" },
          "survivor_id": { "type": "string", "pattern": "^candidate:" },
          "active": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "loser_ids_retained": { "const": true },
    "reversible": { "const": true },
    "input_record_hashes": { "type": "object", "minProperties": 2, "additionalProperties": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" } },
    "mapping_before_hash": { "$ref": "#/$defs/hash" },
    "mapping_after_hash": { "$ref": "#/$defs/hash" },
    "status_history": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/history" } }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "history": {
      "type": "object", "required": ["from", "to", "changed_at", "changed_by", "role", "reason"],
      "properties": {
        "from": { "enum": [null, "applied"] },
        "to": { "enum": ["applied", "reversed"] },
        "changed_at": { "type": "string", "format": "date-time" },
        "changed_by": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
