{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/curation/artwork-rights-preflight.schema.json",
  "title": "Artwork object-level rights preflight",
  "type": "object",
  "required": [
    "schema_version", "id", "entity_type", "candidate_id", "official_object_id", "title",
    "creation_date", "attribution_type", "holding_institution", "accession_number",
    "official_object_url", "rights_page_url", "metadata_license", "media_license",
    "media_license_basis", "rights_evidence", "technical_availability", "delivery_mode",
    "cache_bytes", "attribution_required", "modification_allowed", "github_pages_fit",
    "risk", "reviewed_at", "source_rule_id", "source_id", "adapter_status", "uncertainty",
    "preflight_status", "bytes_downloaded"
  ],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/artwork_id" },
    "entity_type": { "const": "artwork_rights_preflight" },
    "candidate_id": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/candidate_id" },
    "official_object_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "creation_date": { "type": "string", "minLength": 1 },
    "attribution_type": { "enum": ["confirmed", "attributed", "workshop", "circle", "school", "formerly_attributed", "uncertain"] },
    "holding_institution": { "type": "string", "minLength": 1 },
    "accession_number": { "type": ["string", "null"], "minLength": 1 },
    "official_object_url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "rights_page_url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "metadata_license": { "type": "string", "minLength": 1 },
    "media_license": { "enum": ["public_domain", "cc0", "cc_by", "cc_by_sa", "restricted", "unknown"] },
    "media_license_basis": { "enum": ["object_level", "unknown", "restricted"] },
    "rights_evidence": { "type": "array", "items": { "type": "object", "required": ["evidence_type", "url", "snapshot_hash"], "properties": { "evidence_type": { "enum": ["object_rights_statement", "institution_policy_with_object_binding"] }, "url": { "type": "string", "format": "uri", "pattern": "^https://" }, "snapshot_hash": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/hash" } }, "additionalProperties": false } },
    "technical_availability": { "type": "object", "required": ["image_url_present", "iiif_present", "bytes_tested"], "properties": { "image_url_present": { "type": "boolean" }, "iiif_present": { "type": "boolean" }, "bytes_tested": { "const": false } }, "additionalProperties": false },
    "delivery_mode": { "enum": ["metadata_only", "external_link", "iiif_external", "self_hosted_candidate"] },
    "cache_bytes": { "const": false },
    "attribution_required": { "type": "boolean" },
    "modification_allowed": { "enum": ["yes", "no", "unknown"] },
    "github_pages_fit": { "enum": ["yes", "conditional", "no", "unknown"] },
    "risk": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "source_rule_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "adapter_status": { "enum": ["adapter_ready", "manual_preflight_only", "adapter_extension_needed", "source_not_yet_registered"] },
    "uncertainty": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "preflight_status": { "enum": ["rights_path_clear_candidate", "external_iiif_candidate", "external_link_only_candidate", "metadata_only_candidate", "rights_review_required", "blocked_unknown", "blocked_restricted"] },
    "bytes_downloaded": { "const": false }
  },
  "additionalProperties": false
}
