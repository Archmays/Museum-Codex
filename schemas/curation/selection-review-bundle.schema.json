{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/curation/selection-review-bundle.schema.json",
  "title": "Physical MUSEUM-03A selection review bundle manifest",
  "type": "object",
  "required": ["schema_version", "id", "entity_type", "phase_id", "candidate_pool_count", "qualified_candidate_count", "selection_scenario_ids", "recommended_slate_id", "alternate_candidate_ids", "files", "input_hashes", "source_snapshot_hashes", "adapter_versions", "generated_at", "bundle_hash", "user_confirmation_received", "candidate_data_publicly_exposed", "media_downloaded"],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "type": "string", "pattern": "^selection-review-bundle:[0-9a-f-]{36}$" },
    "entity_type": { "const": "selection_review_bundle" },
    "phase_id": { "const": "MUSEUM-03A" },
    "candidate_pool_count": { "type": "integer", "minimum": 0 },
    "qualified_candidate_count": { "type": "integer", "minimum": 0 },
    "selection_scenario_ids": { "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/scenario_id" } },
    "recommended_slate_id": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/scenario_id" },
    "alternate_candidate_ids": { "type": "array", "minItems": 6, "uniqueItems": true, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/candidate_id" } },
    "files": { "type": "array", "minItems": 12, "uniqueItems": true, "items": { "type": "object", "required": ["path", "bytes", "sha256", "content_role"], "properties": { "path": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/safe_path" }, "bytes": { "type": "integer", "minimum": 1 }, "sha256": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/hash" }, "content_role": { "enum": ["candidate_pool", "qualified_pool", "artwork_rights", "relationship_leads", "scenario", "recommended_slate", "alternates", "selection_handoff", "selection_decision_template", "source_snapshots", "review_log"] } }, "additionalProperties": false } },
    "input_hashes": { "type": "object", "minProperties": 1, "propertyNames": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/safe_path" }, "additionalProperties": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/hash" } },
    "source_snapshot_hashes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/hash" } },
    "adapter_versions": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string", "minLength": 1 } },
    "generated_at": { "type": "string", "format": "date-time" },
    "bundle_hash": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/hash" },
    "user_confirmation_received": { "const": false },
    "candidate_data_publicly_exposed": { "const": false },
    "media_downloaded": { "const": false }
  },
  "additionalProperties": false
}
