{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/curation/curation-common.schema.json",
  "title": "MUSEUM-03A curation shared definitions",
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "safe_path": { "type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$" },
    "candidate_id": { "type": "string", "pattern": "^artist-candidate:[0-9a-f-]{36}$" },
    "artwork_id": { "type": "string", "pattern": "^artwork-preflight:[0-9a-f-]{36}$" },
    "lead_id": { "type": "string", "pattern": "^relationship-lead:[0-9a-f-]{36}$" },
    "scenario_id": { "type": "string", "pattern": "^selection-scenario:[0-9a-f-]{36}$" },
    "label": {
      "type": "object",
      "required": ["language", "text"],
      "properties": {
        "language": { "type": "string", "minLength": 2 },
        "text": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "score": {
      "type": "object",
      "required": ["dimension", "score", "rationale", "source_ids", "limitations", "reviewer", "reviewed_at"],
      "properties": {
        "dimension": {
          "enum": [
            "identity_readiness", "death_evidence_readiness", "source_quality",
            "artwork_record_availability", "object_level_media_rights_readiness",
            "multilingual_identity_readiness", "relationship_evidence_potential",
            "geographic_tradition_contribution", "period_contribution",
            "medium_material_contribution", "public_learning_value",
            "interaction_potential", "adapter_pipeline_readiness"
          ]
        },
        "score": { "type": "integer", "minimum": 0, "maximum": 3 },
        "rationale": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "reviewer": { "type": "string", "minLength": 1 },
        "reviewed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "ai_assistance": {
      "type": "object",
      "required": ["runtime_descriptor", "generated_at", "task", "source_inputs", "human_review_status"],
      "properties": {
        "runtime_descriptor": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "task": { "type": "string", "minLength": 1 },
        "source_inputs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "human_review_status": { "enum": ["not_reviewed", "draft_reviewed", "reviewed_for_preflight"] }
      },
      "additionalProperties": false
    }
  }
}
