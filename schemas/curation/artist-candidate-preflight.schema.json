{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/curation/artist-candidate-preflight.schema.json",
  "title": "Artist candidate preflight",
  "type": "object",
  "required": [
    "schema_version", "data_version", "id", "entity_type", "candidate_status",
    "preferred_labels", "aliases", "external_ids", "life_display", "identity_kind", "identity_status",
    "deceased_status", "birth_claim_ids", "death_claim_ids", "authority_source_ids",
    "museum_source_ids", "source_independence", "regions_traditions", "activity_places",
    "historical_periods", "media_materials", "potential_artwork_ids", "artwork_quota_rationale",
    "rights_readiness_summary", "relationship_lead_ids", "public_learning_themes",
    "interaction_opportunities", "adapter_readiness", "hard_gate_results", "score_dimensions",
    "evidence_gaps", "inclusion_rationale", "exclusion_rationale", "bias_notes",
    "reviewer_status", "source_snapshot_hashes", "ai_assistance", "generated_at"
  ],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "data_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/candidate_id" },
    "entity_type": { "const": "artist_candidate_preflight" },
    "candidate_status": { "enum": ["research_candidate", "qualified", "excluded"] },
    "preferred_labels": { "type": "array", "minItems": 2, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/label" } },
    "aliases": { "type": "array", "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/label" } },
    "external_ids": { "type": "object", "additionalProperties": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } },
    "life_display": { "type": "string", "minLength": 3 },
    "identity_kind": { "enum": ["individual", "anonymous", "workshop", "collective", "traditional_attribution", "conventional_identity"] },
    "identity_status": { "enum": ["resolved", "unresolved", "disputed"] },
    "deceased_status": { "enum": ["confirmed_deceased", "living", "unknown", "disputed"] },
    "birth_claim_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "death_claim_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "authority_source_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "museum_source_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "source_independence": { "type": "boolean" },
    "regions_traditions": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["kind", "label", "certainty"], "properties": { "kind": { "enum": ["birth_place", "activity_place", "historical_polity", "artistic_tradition", "cultural_language_context", "later_national_label", "migration", "authority_identity_expression"] }, "label": { "type": "string", "minLength": 1 }, "certainty": { "enum": ["confirmed", "probable", "uncertain", "contested"] } }, "additionalProperties": false } },
    "activity_places": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "historical_periods": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "media_materials": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "potential_artwork_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/artwork_id" } },
    "artwork_quota_rationale": { "type": ["string", "null"], "minLength": 1 },
    "rights_readiness_summary": { "type": "object", "required": ["clear_candidate", "external_iiif", "external_link_only", "metadata_only", "review_required", "blocked_unknown", "blocked_restricted"], "properties": { "clear_candidate": { "type": "integer", "minimum": 0 }, "external_iiif": { "type": "integer", "minimum": 0 }, "external_link_only": { "type": "integer", "minimum": 0 }, "metadata_only": { "type": "integer", "minimum": 0 }, "review_required": { "type": "integer", "minimum": 0 }, "blocked_unknown": { "type": "integer", "minimum": 0 }, "blocked_restricted": { "type": "integer", "minimum": 0 } }, "additionalProperties": false },
    "relationship_lead_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/lead_id" } },
    "public_learning_themes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "interaction_opportunities": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "adapter_readiness": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["source_id", "status", "note"], "properties": { "source_id": { "type": "string", "minLength": 1 }, "status": { "enum": ["adapter_ready", "manual_preflight_only", "adapter_extension_needed", "source_not_yet_registered"] }, "note": { "type": "string", "minLength": 1 } }, "additionalProperties": false } },
    "hard_gate_results": { "type": "object", "minProperties": 14, "additionalProperties": { "type": "boolean" } },
    "score_dimensions": { "type": "array", "minItems": 13, "maxItems": 13, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/score" } },
    "evidence_gaps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "inclusion_rationale": { "type": ["string", "null"], "minLength": 1 },
    "exclusion_rationale": { "type": ["string", "null"], "minLength": 1 },
    "bias_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "reviewer_status": { "enum": ["research_draft", "preflight_reviewed", "excluded_reviewed"] },
    "source_snapshot_hashes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/hash" } },
    "ai_assistance": { "$ref": "https://museum-codex.example/schemas/curation/curation-common.schema.json#/$defs/ai_assistance" },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
