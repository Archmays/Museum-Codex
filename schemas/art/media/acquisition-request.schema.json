{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/media/acquisition-request.schema.json",
  "title": "MUSEUM-03C governed media acquisition request",
  "type": "object",
  "required": [
    "schema_version", "id", "entity_type", "branch_id", "phase_id", "executor",
    "human_review_dependency", "artwork_id", "source_id", "source_object_id",
    "canonical_object_url", "candidate_media_url", "expected_identity", "baseline_media_assessment",
    "network_mode", "download_media",
    "concurrency", "timeout_seconds", "max_bytes", "max_redirects", "trusted_https_hosts",
    "conditional_request", "arbitrary_url_allowed", "cookies_allowed", "request_hash",
    "created_at", "data_version"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "id": { "type": "string", "pattern": "^media-request:[a-z0-9][a-z0-9._-]*$" },
    "entity_type": { "const": "media_acquisition_request" },
    "branch_id": { "const": "art" },
    "phase_id": { "const": "MUSEUM-03C" },
    "executor": { "const": "automated_cross_validation_pipeline" },
    "human_review_dependency": { "const": false },
    "artwork_id": { "$ref": "#/$defs/artworkId" },
    "source_id": { "$ref": "#/$defs/sourceId" },
    "source_object_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "canonical_object_url": { "$ref": "#/$defs/httpsUrl" },
    "candidate_media_url": { "oneOf": [{ "$ref": "#/$defs/httpsUrl" }, { "type": "null" }] },
    "expected_identity": {
      "type": "object",
      "required": [
        "official_object_id", "accession", "artist", "title", "date", "institution",
        "object_url", "source_snapshot_id", "source_snapshot_hash"
      ],
      "properties": {
        "official_object_id": { "type": "string", "minLength": 1 },
        "accession": { "type": ["string", "null"], "minLength": 1 },
        "artist": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "minLength": 1 },
        "institution": { "type": "string", "minLength": 1 },
        "object_url": { "$ref": "#/$defs/httpsUrl" },
        "source_snapshot_id": { "type": "string", "pattern": "^snapshot:[A-Za-z0-9._:-]+$" },
        "source_snapshot_hash": { "$ref": "#/$defs/hash" }
      },
      "additionalProperties": false
    },
    "baseline_media_assessment": {
      "type": "object",
      "required": [
        "assessment_id", "outcome", "media_rights_status", "source_rule_id",
        "rights_statement_url", "verified_at", "reverify_by"
      ],
      "properties": {
        "assessment_id": { "type": "string", "pattern": "^media-assessment:[a-z0-9][a-z0-9._-]*$" },
        "outcome": { "enum": ["self_hosted_open_media_eligible", "external_iiif_candidate", "metadata_only"] },
        "media_rights_status": { "enum": ["public_domain", "cc0", "cc_by", "cc_by_sa", "licensed", "research_or_education_only", "restricted", "unknown", "revoked", "expired"] },
        "source_rule_id": { "type": "string", "pattern": "^[a-z0-9_]+:media:[a-f0-9]{12}$" },
        "rights_statement_url": { "oneOf": [{ "$ref": "#/$defs/httpsUrl" }, { "type": "null" }] },
        "verified_at": { "type": "string", "format": "date-time" },
        "reverify_by": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "network_mode": { "enum": ["offline", "live"] },
    "download_media": { "type": "boolean" },
    "concurrency": { "const": 1 },
    "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 300 },
    "max_bytes": { "type": "integer", "minimum": 1, "maximum": 536870912 },
    "max_redirects": { "type": "integer", "minimum": 0, "maximum": 5 },
    "trusted_https_hosts": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "format": "hostname" }
    },
    "conditional_request": {
      "type": "object",
      "required": ["etag", "last_modified"],
      "properties": {
        "etag": { "type": ["string", "null"], "maxLength": 512 },
        "last_modified": { "type": ["string", "null"], "maxLength": 128 }
      },
      "additionalProperties": false
    },
    "arbitrary_url_allowed": { "const": false },
    "cookies_allowed": { "const": false },
    "request_hash": { "$ref": "#/$defs/hash" },
    "created_at": { "type": "string", "format": "date-time" },
    "data_version": { "$ref": "#/$defs/semver" }
  },
  "allOf": [
    {
      "if": { "properties": { "network_mode": { "const": "offline" } }, "required": ["network_mode"] },
      "then": { "properties": { "download_media": { "const": false } } }
    },
    {
      "if": { "properties": { "download_media": { "const": true } }, "required": ["download_media"] },
      "then": { "properties": { "network_mode": { "const": "live" } } }
    }
  ],
  "$defs": {
    "semver": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "artworkId": { "type": "string", "pattern": "^artwork:[a-z0-9][a-z0-9._-]*$" },
    "sourceId": { "type": "string", "pattern": "^source:[a-z0-9][a-z0-9._-]*$" },
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://" }
  },
  "additionalProperties": false
}
