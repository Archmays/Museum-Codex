{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/media/derivative-record.schema.json",
  "title": "MUSEUM-03C governed web derivative",
  "type": "object",
  "required": [
    "schema_version", "id", "entity_type", "branch_id", "phase_id", "executor",
    "human_review_dependency", "artwork_id", "parent_byte_record_id", "source_sha256", "format", "width",
    "height", "byte_length", "sha256", "storage_path", "transform_steps", "transform_version",
    "rights_modification_allowed", "upscaled", "ai_used", "content_altered", "watermark_removed",
    "generated_at", "data_version"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "id": { "type": "string", "pattern": "^media-derivative:[a-z0-9][a-z0-9._-]*$" },
    "entity_type": { "const": "media_derivative_record" },
    "branch_id": { "const": "art" },
    "phase_id": { "const": "MUSEUM-03C" },
    "executor": { "const": "automated_cross_validation_pipeline" },
    "human_review_dependency": { "const": false },
    "artwork_id": { "type": "string", "pattern": "^artwork:[a-z0-9][a-z0-9._-]*$" },
    "parent_byte_record_id": { "type": "string", "pattern": "^media-byte:[a-z0-9][a-z0-9._-]*$" },
    "source_sha256": { "$ref": "#/$defs/hash" },
    "format": { "enum": ["jpeg", "webp", "avif"] },
    "width": { "type": "integer", "minimum": 1, "maximum": 1600 },
    "height": { "type": "integer", "minimum": 1, "maximum": 50000 },
    "byte_length": { "type": "integer", "minimum": 1 },
    "sha256": { "$ref": "#/$defs/hash" },
    "storage_path": { "$ref": "#/$defs/safePath" },
    "transform_steps": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["orientation", "icc_normalization", "metadata_safe_strip", "resize", "compression"] }
    },
    "transform_version": { "type": "string", "minLength": 1 },
    "rights_modification_allowed": { "const": true },
    "upscaled": { "const": false },
    "ai_used": { "const": false },
    "content_altered": { "const": false },
    "watermark_removed": { "const": false },
    "generated_at": { "type": "string", "format": "date-time" },
    "data_version": { "$ref": "#/$defs/semver" }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    }
  },
  "additionalProperties": false
}
