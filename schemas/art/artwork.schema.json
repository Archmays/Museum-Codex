{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/artwork.schema.json",
  "title": "Art museum artwork",
  "allOf": [
    { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json" },
    {
      "type": "object",
      "required": [
        "creator_attributions", "creation_span", "holding_institution_id", "accession_number",
        "material_ids", "technique_ids", "media_asset_ids", "review_status"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^artwork:[a-z0-9][a-z0-9._-]*$" },
        "entity_type": { "const": "artwork" },
        "branch_id": { "const": "art" },
        "creator_attributions": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object",
            "required": ["attribution_type", "creator_entity_id", "display_label", "claim_id", "public_note"],
            "properties": {
              "attribution_type": { "enum": ["confirmed", "attributed_to", "probably_by", "possibly_by", "workshop_of", "studio_of", "circle_of", "follower_of", "anonymous", "collective", "traditional", "formerly_attributed_to", "unknown"] },
              "creator_entity_id": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9_-]*:[a-z0-9][a-z0-9._-]*$" },
              "display_label": { "type": "string", "minLength": 1 },
              "claim_id": { "type": "string", "pattern": "^claim:[a-z0-9][a-z0-9._-]*$" },
              "public_note": { "type": "string", "minLength": 1 }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "attribution_type": {
                      "enum": ["confirmed", "attributed_to", "probably_by", "possibly_by", "workshop_of", "studio_of", "circle_of", "follower_of", "formerly_attributed_to"]
                    }
                  },
                  "required": ["attribution_type"]
                },
                "then": { "properties": { "creator_entity_id": { "type": "string", "pattern": "^artist:[a-z0-9][a-z0-9._-]*$" } } }
              },
              {
                "if": { "properties": { "attribution_type": { "const": "collective" } }, "required": ["attribution_type"] },
                "then": { "properties": { "creator_entity_id": { "type": "string", "pattern": "^(art_group|organization):[a-z0-9][a-z0-9._-]*$" } } }
              },
              {
                "if": { "properties": { "attribution_type": { "enum": ["anonymous", "traditional", "unknown"] } }, "required": ["attribution_type"] },
                "then": { "properties": { "creator_entity_id": { "type": "null" } } }
              }
            ],
            "additionalProperties": false
          }
        },
        "creation_span": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/timeSpan" },
        "holding_institution_id": { "type": "string", "pattern": "^museum_institution:[a-z0-9][a-z0-9._-]*$" },
        "accession_number": { "type": "string", "minLength": 1 },
        "material_ids": { "type": "array", "items": { "type": "string", "pattern": "^material:[a-z0-9][a-z0-9._-]*$" }, "uniqueItems": true },
        "technique_ids": { "type": "array", "items": { "type": "string", "pattern": "^technique:[a-z0-9][a-z0-9._-]*$" }, "uniqueItems": true },
        "media_asset_ids": { "type": "array", "items": { "type": "string", "pattern": "^media:[a-z0-9][a-z0-9._-]*$" }, "uniqueItems": true },
        "review_status": { "enum": ["candidate", "sourced", "reviewed", "verified", "publishable", "published", "disputed", "withdrawn"] }
      }
    }
  ],
  "if": {
    "properties": { "lifecycle_status": { "enum": ["publishable", "published"] } },
    "required": ["lifecycle_status"]
  },
  "then": {
    "properties": { "review_status": { "enum": ["publishable", "published"] } }
  },
  "unevaluatedProperties": false
}
