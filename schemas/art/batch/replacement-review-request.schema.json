{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/batch/replacement-review-request.schema.json",
  "title": "MUSEUM-03B blocked artist replacement review request",
  "type": "object",
  "required": [
    "schema_version", "id", "entity_type", "phase_id", "batch_id", "selection_decision_id",
    "selection_application_id", "failed_approved_candidate_id", "failed_artist_id",
    "blocking_error_codes", "evidence_ids", "reason", "status", "proposed_replacement_candidate_id",
    "automatic_replacement", "graph_input_blocked", "requested_by", "requested_at",
    "decision_authority_required", "review_signoff_ids", "data_version"
  ],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "type": "string", "pattern": "^replacement-review-request:[a-z0-9][a-z0-9._-]*$" },
    "entity_type": { "const": "replacement_review_request" },
    "phase_id": { "const": "MUSEUM-03B" },
    "batch_id": { "$ref": "#/$defs/batchId" },
    "selection_decision_id": { "type": "string", "pattern": "^selection-decision:[a-f0-9-]{36}$" },
    "selection_application_id": { "type": "string", "pattern": "^selection-decision-application:[a-f0-9-]{36}$" },
    "failed_approved_candidate_id": { "type": "string", "pattern": "^artist-candidate:[a-f0-9-]{36}$" },
    "failed_artist_id": { "type": "string", "pattern": "^artist:[a-z0-9][a-z0-9._-]*$" },
    "blocking_error_codes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "evidence_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^evidence:[a-z0-9][a-z0-9._-]*$" }
    },
    "reason": { "type": "string", "minLength": 1 },
    "status": { "enum": ["submitted", "under_review", "approved", "rejected"] },
    "proposed_replacement_candidate_id": {
      "oneOf": [
        { "type": "string", "pattern": "^artist-candidate:[a-f0-9-]{36}$" },
        { "type": "null" }
      ]
    },
    "automatic_replacement": { "const": false },
    "graph_input_blocked": { "const": true },
    "requested_by": { "type": "string", "minLength": 1 },
    "requested_at": { "type": "string", "format": "date-time" },
    "decision_authority_required": { "const": "Mays" },
    "review_signoff_ids": {
      "type": "array", "uniqueItems": true,
      "items": { "type": "string", "pattern": "^review-signoff:[a-z0-9][a-z0-9._-]*$" }
    },
    "data_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "approved" } }, "required": ["status"] },
      "then": {
        "properties": {
          "proposed_replacement_candidate_id": { "type": "string", "pattern": "^artist-candidate:[a-f0-9-]{36}$" },
          "review_signoff_ids": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "batchId": { "type": "string", "pattern": "^art-batch:museum-03b-[a-z0-9][a-z0-9._-]*$" }
  },
  "additionalProperties": false
}
