{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/batch/manual-evidence-capture.schema.json",
  "title": "MUSEUM-03B controlled manual official evidence capture",
  "type": "object",
  "required": [
    "schema_version", "id", "entity_type", "phase_id", "batch_id", "capture_method",
    "source_id", "source_tier", "source_object_id", "official_url", "accessed_at",
    "page_title", "publisher", "locator", "fact_fields", "raw_snapshot_id", "raw_capture_hash",
    "terms_url", "rights_url", "raw_storage_class", "raw_bytes_tracked", "reviewed_by",
    "reviewed_at", "content_hash", "data_version"
  ],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "type": "string", "pattern": "^manual-evidence-capture:[a-z0-9][a-z0-9._-]*$" },
    "entity_type": { "const": "manual_evidence_capture" },
    "phase_id": { "const": "MUSEUM-03B" },
    "batch_id": { "$ref": "#/$defs/batchId" },
    "capture_method": { "const": "manual_official_capture" },
    "source_id": { "type": "string", "pattern": "^source:[a-z0-9][a-z0-9._-]*$" },
    "source_tier": { "enum": [1, 2, 3, 4] },
    "source_object_id": { "type": "string", "minLength": 1 },
    "official_url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "accessed_at": { "type": "string", "format": "date-time" },
    "page_title": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "locator": {
      "type": "object",
      "required": ["section_or_field", "locator_text"],
      "properties": {
        "section_or_field": { "type": "string", "minLength": 1 },
        "locator_text": { "type": "string", "minLength": 1, "maxLength": 500 }
      },
      "additionalProperties": false
    },
    "fact_fields": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["field_name", "value", "language", "claim_id"],
        "properties": {
          "field_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "value": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "language": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/languageTag" },
          "claim_id": { "type": "string", "pattern": "^claim:[a-z0-9][a-z0-9._-]*$" }
        },
        "additionalProperties": false
      }
    },
    "raw_snapshot_id": { "type": "string", "pattern": "^snapshot:[a-z][a-z0-9_]*:[a-z0-9.:_-]+$" },
    "raw_capture_hash": { "$ref": "#/$defs/hash" },
    "terms_url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "rights_url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "raw_storage_class": { "const": "ignored_evidence" },
    "raw_bytes_tracked": { "const": false },
    "reviewed_by": { "type": "string", "minLength": 1 },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "content_hash": { "$ref": "#/$defs/hash" },
    "data_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" }
  },
  "$defs": {
    "batchId": { "type": "string", "pattern": "^art-batch:museum-03b-[a-z0-9][a-z0-9._-]*$" },
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
