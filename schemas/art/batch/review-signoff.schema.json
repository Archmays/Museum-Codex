{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/batch/review-signoff.schema.json",
  "title": "MUSEUM-03B role-specific review sign-off",
  "type": "object",
  "required": [
    "schema_version", "id", "entity_type", "record_ids", "review_role", "reviewer_id",
    "reviewer_kind", "single_operator_multi_role", "reviewed_at", "checklist",
    "decision", "decision_note", "authority_basis", "data_version"
  ],
  "properties": {
    "schema_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" },
    "id": { "type": "string", "pattern": "^review-signoff:[a-z0-9][a-z0-9._-]*$" },
    "entity_type": { "const": "review_signoff" },
    "record_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/stableId" }
    },
    "review_role": {
      "enum": [
        "identity_reviewer", "art_history_reviewer", "artwork_attribution_reviewer",
        "relationship_reviewer", "rights_reviewer", "multilingual_reviewer",
        "data_reviewer", "release_reviewer"
      ]
    },
    "reviewer_id": { "type": "string", "minLength": 1 },
    "reviewer_kind": { "enum": ["human", "ai_assisted_operator", "automated_check"] },
    "single_operator_multi_role": { "type": "boolean" },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "checklist": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check", "result", "note"],
        "properties": {
          "check": { "type": "string", "minLength": 1 },
          "result": { "enum": ["pass", "fail", "not_applicable"] },
          "note": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "decision": { "enum": ["accepted_reviewed", "accepted_verified", "blocked", "changes_required"] },
    "decision_note": { "type": "string", "minLength": 1 },
    "authority_basis": { "type": "string", "minLength": 1 },
    "data_version": { "$ref": "https://museum-codex.example/schemas/common/entity.schema.json#/$defs/semver" }
  },
  "allOf": [
    {
      "if": { "properties": { "reviewer_kind": { "enum": ["ai_assisted_operator", "automated_check"] } }, "required": ["reviewer_kind"] },
      "then": { "properties": { "decision": { "not": { "const": "accepted_verified" } } } }
    },
    {
      "if": { "properties": { "decision": { "enum": ["blocked", "changes_required"] } }, "required": ["decision"] },
      "then": { "properties": { "checklist": { "contains": { "properties": { "result": { "const": "fail" } }, "required": ["result"] } } } }
    }
  ],
  "additionalProperties": false
}
