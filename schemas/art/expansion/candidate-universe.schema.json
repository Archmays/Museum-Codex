{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/expansion/candidate-universe.schema.json",
  "title": "MUSEUM-09A normalized artist candidate universe",
  "type": "object",
  "required": ["schema_version", "phase_id", "candidate_count", "candidates"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "phase_id": { "const": "MUSEUM-09A" },
    "candidate_count": { "type": "integer", "minimum": 700 },
    "candidates": {
      "type": "array",
      "minItems": 700,
      "items": { "$ref": "#/$defs/candidate" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "candidate": {
      "type": "object",
      "required": [
        "id",
        "entity_type",
        "artist_kind",
        "preferred_name",
        "birth",
        "death",
        "deceased_status",
        "deceased_verification_evidence_ids",
        "source_identities",
        "duplicate_cluster_id",
        "primary_coverage_bucket",
        "primary_coverage_basis",
        "historical_period",
        "documented_media_practice_tags",
        "content_depth_tier",
        "status",
        "status_history",
        "what_is_proven",
        "what_is_not_proven",
        "selection_reason_codes"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^artist:" },
        "entity_type": { "const": "artist_expansion_candidate" },
        "artist_kind": { "const": "individual" },
        "preferred_name": { "type": "string", "minLength": 1 },
        "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "birth": { "$ref": "#/$defs/lifeDate" },
        "death": {
          "type": "object",
          "required": ["year", "precision"],
          "properties": {
            "year": { "type": "integer", "maximum": 2026 },
            "precision": { "const": "year" }
          },
          "additionalProperties": false
        },
        "deceased_status": { "const": "confirmed_deceased" },
        "deceased_verification_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^deceased-evidence:" },
          "uniqueItems": true
        },
        "external_ids": { "type": "object" },
        "source_identities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source_id", "source_artist_id"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_artist_id": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "duplicate_cluster_id": { "type": "string", "pattern": "^artist-duplicate:" },
        "primary_coverage_bucket": {
          "enum": [
            "africa",
            "east-asia",
            "europe",
            "latin-america-caribbean",
            "north-america",
            "oceania",
            "south-asia",
            "southeast-asia",
            "west-central-asia"
          ]
        },
        "primary_coverage_basis": { "type": "string", "minLength": 1 },
        "secondary_region_context_tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "historical_period": {
          "enum": [
            "before-1400",
            "1400-1599",
            "1600-1799",
            "1800-1899",
            "1900-1949",
            "1950-onward"
          ]
        },
        "documented_media_practice_tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "content_depth_tier": { "enum": ["gallery", "collection", "discovery-only"] },
        "status": { "enum": ["program_target", "reserve", "rejected", "blocked"] },
        "status_history": { "type": "array", "minItems": 3 },
        "what_is_proven": { "type": "array", "minItems": 1 },
        "what_is_not_proven": { "type": "array", "minItems": 1 },
        "conflict_notes": { "type": "array" },
        "reserve_order": { "type": ["integer", "null"], "minimum": 1 },
        "candidate_batch": { "type": ["string", "null"] },
        "legacy_existing": { "type": "boolean" },
        "selection_reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "propertyNames": {
        "not": {
          "pattern": "(?i)(importance|popularity|market|western_canon|museum_fame|social_media|query_frequency|ai_aesthetic).*score"
        }
      },
      "additionalProperties": false
    },
    "lifeDate": {
      "type": "object",
      "required": ["year", "precision"],
      "properties": {
        "year": { "type": ["integer", "null"] },
        "precision": { "enum": ["year", "unknown"] }
      },
      "additionalProperties": false
    }
  }
}
