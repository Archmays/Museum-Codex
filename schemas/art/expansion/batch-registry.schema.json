{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://museum-codex.example/schemas/art/expansion/batch-registry.schema.json",
  "title": "MUSEUM-09 deterministic expansion batch registry",
  "type": "object",
  "required": [
    "schema_version",
    "phase_id",
    "legacy_baseline",
    "legacy_target_supplement",
    "batch_count",
    "batches",
    "reserve_replacement_order",
    "assignment_contract"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "phase_id": { "const": "MUSEUM-09A" },
    "legacy_baseline": {
      "type": "object",
      "required": ["artist_count", "work_count", "artist_ids", "work_ids", "status"],
      "properties": {
        "artist_count": { "const": 12 },
        "work_count": { "const": 44 },
        "artist_ids": { "type": "array", "minItems": 12, "maxItems": 12, "uniqueItems": true },
        "work_ids": { "type": "array", "minItems": 44, "maxItems": 44, "uniqueItems": true },
        "status": { "const": "reference_only_not_rebuilt" }
      },
      "additionalProperties": false
    },
    "legacy_target_supplement": {
      "type": "object",
      "required": ["artist_ids", "work_ids", "status", "note"],
      "properties": {
        "artist_ids": { "type": "array", "minItems": 12, "maxItems": 12, "uniqueItems": true },
        "work_ids": { "type": "array", "minItems": 1, "uniqueItems": true },
        "status": { "const": "registered_not_started" },
        "note": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "batch_count": { "const": 10 },
    "batches": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "id",
          "sequence",
          "planned_phase",
          "status",
          "artist_count",
          "work_count",
          "artist_ids",
          "coverage_delta",
          "gallery_tier_count",
          "collection_tier_count",
          "input_closure_hash",
          "source_set",
          "workload",
          "risks",
          "dependencies"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^museum-09-batch-[0-9]{2}$" },
          "sequence": { "type": "integer", "minimum": 1, "maximum": 10 },
          "planned_phase": { "type": "string", "pattern": "^MUSEUM-09[A-Z]$" },
          "status": {
            "enum": [
              "registered_not_started",
              "research_in_progress",
              "formal_candidate_ready",
              "media_bundle_ready",
              "published",
              "blocked",
              "withdrawn"
            ]
          },
          "artist_count": { "type": "integer", "minimum": 48, "maximum": 50 },
          "work_count": { "type": "integer", "minimum": 450, "maximum": 550 },
          "artist_ids": { "type": "array", "minItems": 48, "maxItems": 50, "uniqueItems": true },
          "coverage_delta": { "type": "object", "minProperties": 1 },
          "gallery_tier_count": { "type": "integer", "minimum": 0 },
          "collection_tier_count": { "type": "integer", "minimum": 0 },
          "input_closure_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "source_set": { "type": "array", "minItems": 1, "uniqueItems": true },
          "workload": { "type": "string", "minLength": 1 },
          "risks": { "type": "array" },
          "dependencies": { "type": "array" },
          "status_history": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to", "at", "actor"],
              "properties": {
                "from": {
                  "enum": [
                    "registered_not_started",
                    "research_in_progress",
                    "formal_candidate_ready",
                    "media_bundle_ready"
                  ]
                },
                "to": {
                  "enum": [
                    "research_in_progress",
                    "formal_candidate_ready",
                    "media_bundle_ready",
                    "published",
                    "blocked",
                    "withdrawn"
                  ]
                },
                "at": { "type": "string", "minLength": 1 },
                "actor": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true,
        "allOf": [
          {
            "if": {
              "properties": { "status": { "const": "published" } },
              "required": ["status"]
            },
            "then": {
              "required": [
                "formal_package_id",
                "formal_package_content_hash",
                "formal_package_tree_hash",
                "media_package_id",
                "media_package_content_hash",
                "media_package_tree_hash",
                "current_release",
                "public_release_created",
                "online_closure",
                "next_authorized_phase"
              ],
              "anyOf": [
                { "required": ["runtime_commits", "deployments"] },
                { "required": ["runtime_binding", "deployment_binding"] }
              ]
            }
          }
        ]
      }
    },
    "reserve_replacement_order": {
      "type": "array",
      "minItems": 100,
      "items": { "type": "string", "pattern": "^artist:" },
      "uniqueItems": true
    },
    "assignment_contract": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
